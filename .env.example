# 任选其一填写。都不填则尝试本机 claude CLI（Claude Code 订阅）。
# 显式指定 provider（可选）: cli | anthropic | deepseek | glm | kimi | openai
# MAFIA_PROVIDER=anthropic

# --- Anthropic（persona 保真度最佳）---
# ANTHROPIC_API_KEY=sk-ant-xxxx
# MAFIA_MODEL=claude-sonnet-4-6

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-xxxx

# --- 智谱 GLM ---
# GLM_API_KEY=xxxx
# MAFIA_MODEL=glm-4-plus

# --- 任意 OpenAI 兼容端点（Kimi / 本地 / 其他）---
# MAFIA_PROVIDER=openai
# OPENAI_COMPAT_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_COMPAT_API_KEY=sk-xxxx
# OPENAI_COMPAT_MODEL=moonshot-v1-32k
